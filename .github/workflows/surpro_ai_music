name: Build APK
on: workflow_dispatch
jobs:
  build:
    runs-on: ubuntu-latest
    steps:
      - uses: actions/checkout@v4
      
      - uses: actions/setup-java@v4
        with:
          distribution: 'zulu'
          java-version: '17'
          
      - uses: subosito/flutter-action@v2
        with:
          flutter-version: '3.22.0'
          channel: 'stable'
          
      - name: Clean old project files
        run: rm -rf pubspec.yaml lib/ test/ android/ ios/ web/ linux/ macos/ windows/
        
      - name: Create New Flutter Project
        run: flutter create --project-name surpro_ai_music --org com.surpro --platforms android .
        
      - name: Update main.dart
        run: |
          cat > lib/main.dart << 'EOF'
          import 'package:flutter/material.dart';
          void main() => runApp(MyApp());
          class MyApp extends StatelessWidget {
            @override
            Widget build(BuildContext context) {
              return MaterialApp(
                title: 'SurPro AI Music',
                debugShowCheckedModeBanner: false,
                home: Scaffold(
                  appBar: AppBar(title: Text('SurPro AI Music')),
                  body: Center(child: Text('APK Build Success ✅', style: TextStyle(fontSize: 24))),
                ),
              );
            }
          }
          EOF
          
      - name: Get dependencies
        run: flutter pub get
        
      - name: Build APK Release
        run: flutter build apk --release
        
      - name: Upload APK
        uses: actions/upload-artifact@v4
        with:
          name: SurPro-AI-Music
          path: build/app/outputs/flutter-apk/app-release.apk
